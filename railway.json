{
  "services": [
    {
      "name": "grocery-backend",
      "rootDirectory": "backend",
      "buildCommand": "pip install -r requirements.txt && python manage.py migrate",
      "startCommand": "gunicorn backend.wsgi:application",
      "type": "web",
      "env": [
        {"key": "SECRET_KEY", "generateValue": true},
        {"key": "DEBUG", "value": "false"},
        {"key": "ALLOWED_HOSTS", "value": "grocery-backend.up.railway.app"},
        {"key": "DATABASE_URL", "fromDatabase": {"name": "grocery-db", "property": "connectionString"}},
        {"key": "CORS_ALLOWED_ORIGINS", "value": "https://grocery-frontend.up.railway.app"},
        {"key": "CSRF_TRUSTED_ORIGINS", "value": "https://grocery-frontend.up.railway.app"}
      ]
    },
    {
      "name": "grocery-frontend",
      "rootDirectory": "frontend",
      "buildCommand": "npm ci && npm run build",
      "publishDirectory": "dist",
      "type": "static",
      "env": [
        {"key": "VITE_API_BASE_URL", "value": "https://grocery-backend.up.railway.app/api/grocery"}
      ]
    }
  ],
  "databases": [
    {
      "name": "grocery-db",
      "plan": "free"
    }
  ]
}